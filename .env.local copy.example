# Kopiera den här filen till .env.local och ändra värdena.

# Lösenord för att komma åt sidan (alla medlemmar).
SITE_PASSWORD=byt-mig-medlem

# Lösenord för adminbehörighet (redigera ansvarsområden m.m.).
ADMIN_PASSWORD=byt-mig-admin

# Hemlig nyckel som används för att signera inloggningskakan.
# Sätt en lång slumpmässig sträng (t.ex. från `openssl rand -hex 32`).
AUTH_SECRET=byt-mig-till-en-lang-slumpmassig-strang

# Endast i produktion (Vercel): Upstash Redis för att spara ansvarsområden.
# Sätts automatiskt av Upstash-integrationen på Vercel. Behövs INTE lokalt –
# lokalt används data/responsibilities.json.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
